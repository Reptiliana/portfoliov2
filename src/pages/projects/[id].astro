---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { Image } from 'astro:assets';
import snakeIcon from '../../assets/snake.svg';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const name = "Reptiliana";
const title = `${project.data.name} - ${name}`;
---

<Layout title={title}>
  <div class="relative min-h-screen">
    <!-- Unified Background Atmospheric Elements -->
    <div class="fixed inset-0 -z-10 pointer-events-none overflow-hidden">
      <div class="glow-blob w-64 h-64 md:w-[600px] md:h-[600px] -top-20 -left-32 md:-left-64"></div>
      <div class="glow-blob w-48 h-48 md:w-[500px] md:h-[500px] top-[40%] -right-16 md:-right-32" style="background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);"></div>
      <div class="glow-blob w-56 h-56 md:w-[400px] md:h-[400px] -bottom-20 -left-10 md:-left-20"></div>
    </div>

    <header class="max-w-screen-xl mx-auto px-6 py-8 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <button 
          onclick="history.back()" 
          class="text-2xl hover:scale-110 transition-transform cursor-pointer" 
          aria-label="Volver al inicio"
        >
          ←
        </button>
        <a href="/" class="hover:scale-110 transition-transform">
          <Image src={snakeIcon} alt="Snake Logo" class="w-8 h-8" />
        </a>
      </div>
      <nav class="flex gap-8 text-sm font-medium text-muted items-center">
        <a href="/" class="hover:text-foreground transition-colors">Inicio</a>
        <ThemeToggle />
      </nav>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-20 relative">
      <article class="prose prose-zinc dark:prose-invert prose-lg md:prose-xl max-w-none relative z-10">
        <p class="text-muted text-sm uppercase tracking-[0.2em] font-bold mb-4" transition:name={`category-${project.id}`}>{project.data.category}</p>
        <h1 class="text-4xl md:text-7xl font-black tracking-tight mb-12 leading-tight" transition:name={`title-${project.id}`}>
          {project.data.name}
        </h1>
        <div class="mt-12">
          <Content />
        </div>
      </article>
    </main>

    <footer class="max-w-screen-xl mx-auto px-6 py-32 border-t border-border flex flex-col items-center gap-8 text-muted text-sm font-medium">
      <div class="flex gap-8 justify-center">
        <a href="https://github.com/reptiliana" class="hover:text-foreground transition-colors">GitHub</a>
        <a href="mailto:ru1iziliana.avi@gmail.com" class="hover:text-foreground transition-colors">Email</a>
      </div>
      <p class="text-center">© {new Date().getFullYear()} {name}. Todos los derechos reservados.</p>
    </footer>
  </div>
</Layout>
