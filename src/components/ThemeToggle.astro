<button
  class="theme-toggle p-2 rounded-xl bg-card text-foreground hover:scale-110 transition-all border border-border shadow-sm flex items-center justify-center w-10 h-10"
  aria-label="Toggle theme"
>
  <span class="hidden dark:inline">☀️</span>
  <span class="inline dark:hidden">🌙</span>
</button>

<script>
  function setupToggle() {
    const buttons = document.querySelectorAll(".theme-toggle");
    buttons.forEach(button => {
      button.removeEventListener("click", toggleTheme);
      button.addEventListener("click", toggleTheme);
    });
  }

  function toggleTheme() {
    const element = document.documentElement;
    element.classList.toggle("dark");
    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  // Initialize on script load
  setupToggle();

  // Re-initialize after Astro page transitions
  document.addEventListener('astro:after-swap', setupToggle);
  document.addEventListener('astro:page-load', setupToggle);
</script>
